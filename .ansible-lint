---
# ansible-lint configuration
profile: moderate

# Exclude specific rules that are not relevant for this project
skip_list:
  - 'yaml[line-length]'  # Allow longer lines for readability
  - 'name[casing]'  # Allow flexible task naming
  - 'fqcn[action-core]'  # Allow use of short module names

# Enable offline mode for faster linting
offline: false

# Exclude patterns
exclude_paths:
  - .github/
  - windows/
